# Application
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://carousel:carousel_secret@db:5432/carousel_db

# S3 / MinIO
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=carousel-assets
S3_REGION=us-east-1
S3_USE_SSL=false

# LLM (OpenAI-compatible). Пример для ProxyAPI: https://console.proxyapi.ru/keys
LLM_PROVIDER=openai
LLM_API_KEY=your-api-key
LLM_MODEL=gpt-4o-mini
# Для ProxyAPI (обязательно):
LLM_BASE_URL=https://api.proxyapi.ru/openai/v1

# Export (Playwright)
EXPORT_VIEWPORT_WIDTH=1080
EXPORT_VIEWPORT_HEIGHT=1350
PLAYWRIGHT_BROWSER_PATH=/usr/bin/chromium

# Frontend (for CORS and Nuxt)
FRONTEND_URL=http://localhost:3000
NUXT_PUBLIC_API_BASE=http://localhost:8000
